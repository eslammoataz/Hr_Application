{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithProcessId" ]
  },
  "SeqSettings": {
    "Enabled": false,
    "ServerUrl": "http://localhost:5341"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5444;Database=HrSystemApp;Username=admin;Password=Password2024"
  },
  "JwtSettings": {
    "Secret": "CHANGE_ME_USE_ENV_VAR_OR_SECRETS_MANAGER_32CHARS_MIN!",
    "Issuer": "HrSystemApp",
    "Audience": "HrSystemApp",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 30
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "",
    "SenderName": "HR System",
    "AppPassword": ""
  }
}